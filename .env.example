# ============================================================
# kira_caster 환경변수 설정
# 이 파일을 .env 로 복사한 뒤 값을 채워주세요:
#   cp .env.example .env
# ============================================================

# --- 기본 설정 (선택) ---
# 데이터베이스 파일 경로
KIRA_DB_PATH=kira_caster.db
# 대시보드 포트
KIRA_ADMIN_PORT=8080
# 대시보드 관리자 비밀번호 (비워두면 누구나 접근 가능)
KIRA_ADMIN_KEY=
# 서버 암호화 키 (운영 환경에서는 반드시 변경)
KIRA_SECRET_KEY=

# --- 게임 포인트 (선택, 기본값 사용 가능) ---
# KIRA_ATTENDANCE_POINTS=10
# KIRA_DICE_WIN_POINTS=50
# KIRA_DICE_LOSS_POINTS=-20
# KIRA_RPS_WIN_POINTS=30
# KIRA_RPS_LOSS_POINTS=-10
# KIRA_COOLDOWN_MS=5000

# --- 씨미(ci.me) 연동 (선택, 비워두면 테스트 모드로 실행) ---
# 씨미 개발자 센터에서 발급: https://ci.me/developer
CIME_CLIENT_ID=
CIME_CLIENT_SECRET=
# OAuth 콜백 URL (보통 http://localhost:8080/oauth/callback)
CIME_REDIRECT_URI=http://localhost:8080/oauth/callback
# 봇이 연결할 채널 ID (씨미 연동 후 대시보드에서 자동 조회됩니다)
CIME_CHANNEL_ID=

# --- YouTube (선택) ---
# YouTube Data API 키 (신청곡 제목/길이 자동 조회)
# KIRA_YOUTUBE_API_KEY=
